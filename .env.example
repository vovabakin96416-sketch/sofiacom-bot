# === Telegram-бот (обязательно) ===
BOT_TOKEN=твой_токен_от_BotFather
ADMIN_ID=твой_telegram_id

# === Каналы ===
CHANNEL_ID=@sofia_gada1ka
TEST_CHANNEL_ID=@dfgyugsdiufyhg

# === Кампания контента ===
# Дата старта кампании YYYY-MM-DD — от неё считается номер недели (1-4 по кругу).
CAMPAIGN_START=2026-06-15

# === Фото для постов (необязательно) ===
# Ключ Pexels API. Если задан — бот подбирает фото по pexels_query из content.json.
# Бесплатный ключ: https://www.pexels.com/api/
PEXELS_API_KEY=

# === Аналитика Telethon (необязательно, для analytics.py) ===
# my.telegram.org → Apps → создай приложение → возьми API_ID и API_HASH.
# TELETHON_SESSION получают, запустив generate_session.py ОДИН РАЗ локально.
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION=
